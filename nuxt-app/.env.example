# ── Piloto Guardados (Nuxt/Nitro) ──────────────────────────────
# Copia este archivo a `.env` (gitignored) y rellena los valores REALES
# de Vercel (Settings → Environment Variables del proyecto almacen-sistema).
#
# Sin estas variables el piloto arranca en MODO DEMO (datos de ejemplo).
# Con ellas + una sesión activa (login en la app Next.js en el mismo
# navegador / dominio), muestra y escribe datos REALES en la misma DB.

# Cadena de conexión Postgres (Railway). Usa la conexión directa.
DATABASE_URL=

# Opcional: pooler PgBouncer (puerto 6543) si está activo.
# DATABASE_POOL_URL=

# Secreto de Auth.js v5 — DEBE ser el mismo NEXTAUTH_SECRET de la app Next.js
# para poder verificar la cookie de sesión (authjs.session-token).
NEXTAUTH_SECRET=
