// ═══════════════════════════════════════════════════════════════════
// MÓDULO CARGUE GOURMET (diseño G1, aún no expuesto en UI/endpoints)
// ═══════════════════════════════════════════════════════════════════

enum EstadoPedidoGourmet {
  BORRADOR
  UBICACION_ASIGNADA
  ENVIADO_A_TRANSPORTE
  EN_CARGUE
  CARGUE_COMPLETO
  CARGUE_COMPLETO_MANUAL
  CON_NOVEDAD
  CANCELADO
}

// Tipo de carga del pedido — GOURMET (por defecto) exige códigos de caja
// únicos sin repetir; MUEBLES permite repetir un número de caja cuando el
// mueble viene en más de una parte física (ver "tiene parte 2" en el
// escaneo), contando cada parte como una caja adicional.
enum TipoPedidoGourmet {
  GOURMET
  MUEBLES
}

enum TipoCierreCargue {
  NORMAL
  MANUAL
}

enum ResultadoEscaneoGourmet {
  VALIDO
  DUPLICADO
  CAJA_AJENA
  FORMATO_INVALIDO
  EXCEDE_CANTIDAD
}

enum TipoNovedadGourmet {
  CAJA_FALTANTE
  CAJA_DUPLICADA
  CAJA_AJENA
  CIERRE_MANUAL
  DIFERENCIA_CANTIDAD
  OTRA
}

enum EstadoNovedadGourmet {
  ABIERTA
  RESUELTA
}

model MaestroTiendaGourmet {
  id        String   @id @default(cuid())
  codigo    String   @unique @db.VarChar(50)
  tienda    String   @db.VarChar(255)
  ciudad    String   @db.VarChar(80)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("maestro_tiendas_gourmet")
}

model GourmetPedido {
  id               String              @id @default(cuid())
  orden            String              @db.VarChar(100)
  tipoOrden        String              @map("tipo_orden") @db.VarChar(10) // "OVDM" | "TSDM"
  codigoTienda     String              @map("codigo_tienda") @db.VarChar(50)
  nombreTienda     String              @map("nombre_tienda") @db.VarChar(255)
  ciudadDestino    String              @map("ciudad_destino") @db.VarChar(80)
  cajasEsperadas   Int                 @map("cajas_esperadas")
  estibasEsperadas Int                 @map("estibas_esperadas")
  estado           EstadoPedidoGourmet @default(BORRADOR)
  tipoPedido       TipoPedidoGourmet   @default(GOURMET) @map("tipo_pedido")

  creadoPorId String   @map("creado_por_id")
  creadoPor   User     @relation("GourmetPedidosCreados", fields: [creadoPorId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Transición: ubicación asignada
  ubicacionAsignadaAt    DateTime? @map("ubicacion_asignada_at")
  ubicacionAsignadaPorId String?   @map("ubicacion_asignada_por_id")

  // Transición: enviado a Transporte
  enviadoTransporteAt    DateTime? @map("enviado_transporte_at")
  enviadoTransportePorId String?   @map("enviado_transporte_por_id")

  // Transición: cargue iniciado
  cargueIniciadoAt    DateTime? @map("cargue_iniciado_at")
  cargueIniciadoPorId String?   @map("cargue_iniciado_por_id")

  // Transición: cargue completado (normal o manual)
  cargueCompletadoAt    DateTime? @map("cargue_completado_at")
  cargueCompletadoPorId String?   @map("cargue_completado_por_id")

  // Cierre manual de contingencia
  esCierreManual          Boolean @default(false) @map("es_cierre_manual")
  cantidadContadaManual   Int?    @map("cantidad_contada_manual")
  motivoCierreManual      String? @map("motivo_cierre_manual")
  observacionCierreManual String? @map("observacion_cierre_manual")

  estibas   GourmetPedidoEstiba[]
  cajas     GourmetPedidoCaja[]
  cargues   GourmetCargue[]
  novedades GourmetCargueNovedad[]

  @@index([orden])
  @@index([tipoOrden])
  @@index([codigoTienda])
  @@index([ciudadDestino])
  @@index([estado, createdAt])
  @@index([createdAt])
  @@index([enviadoTransporteAt])
  @@index([cargueIniciadoAt])
  @@map("gourmet_pedidos")
}

model GourmetPedidoEstiba {
  id          String              @id @default(cuid())
  pedidoId    String              @map("pedido_id")
  pedido      GourmetPedido       @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  secuencia   Int
  // ubicacion es nullable para permitir crear estibas durante el escaneo
  // inicial (creación del pedido, G1), antes de asignarles ubicación física.
  // Al "Asignar ubicación" se rellena. Pedidos legacy tienen ubicacion siempre.
  ubicacion   String?             @db.VarChar(120)
  observacion String?
  createdAt   DateTime            @default(now()) @map("created_at")
  cajas       GourmetPedidoCaja[]

  @@unique([pedidoId, secuencia])
  @@index([pedidoId])
  @@map("gourmet_pedido_estibas")
}

model GourmetPedidoCaja {
  id                 String               @id @default(cuid())
  pedidoId           String               @map("pedido_id")
  pedido             GourmetPedido        @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  // Estiba a la que pertenece esta caja. Nullable para retro-compat: cajas
  // creadas antes de G1 (vía "Asignar ubicación" sin estiba explícita) no
  // tienen estibaId. Las creadas desde G2+ siempre lo tendrán.
  estibaId           String?              @map("estiba_id")
  estiba             GourmetPedidoEstiba? @relation(fields: [estibaId], references: [id], onDelete: SetNull)
  codigoCaja         String?              @map("codigo_caja") @db.VarChar(150)
  numeroSecuencia    Int?                 @map("numero_secuencia")
  generadaPorEscaneo Boolean              @default(false) @map("generada_por_escaneo")
  estado             String?              @db.VarChar(20)
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  @@index([pedidoId])
  @@index([estibaId])
  @@index([codigoCaja])
  @@index([pedidoId, numeroSecuencia])
  @@map("gourmet_pedido_cajas")
}

model GourmetCargue {
  id       String        @id @default(cuid())
  pedidoId String        @map("pedido_id")
  pedido   GourmetPedido @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  iniciadoPorId   String    @map("iniciado_por_id")
  iniciadoAt      DateTime  @default(now()) @map("iniciado_at")
  finalizadoPorId String?   @map("finalizado_por_id")
  finalizadoAt    DateTime? @map("finalizado_at")

  tipoCierre            TipoCierreCargue? @map("tipo_cierre")
  cantidadEsperada      Int               @map("cantidad_esperada")
  cantidadEscaneada     Int               @default(0) @map("cantidad_escaneada")
  cantidadContadaManual Int?              @map("cantidad_contada_manual")
  motivoCierreManual    String?           @map("motivo_cierre_manual")
  observacion           String?

  estado EstadoPedidoGourmet @default(EN_CARGUE)

  escaneos  GourmetCargueEscaneo[]
  novedades GourmetCargueNovedad[]

  @@index([pedidoId, iniciadoAt])
  @@index([estado])
  @@map("gourmet_cargues")
}

model GourmetCargueEscaneo {
  id              String                  @id @default(cuid())
  cargueId        String                  @map("cargue_id")
  cargue          GourmetCargue           @relation(fields: [cargueId], references: [id], onDelete: Cascade)
  pedidoId        String                  @map("pedido_id")
  codigoEscaneado String                  @map("codigo_escaneado") @db.VarChar(150)
  resultado       ResultadoEscaneoGourmet
  escaneadoPorId  String                  @map("escaneado_por_id")
  observacion     String?
  createdAt       DateTime                @default(now()) @map("created_at")

  @@index([cargueId])
  @@index([cargueId, codigoEscaneado])
  @@index([cargueId, resultado], map: "idx_gourmet_escaneo_cargue_resultado")
  @@index([codigoEscaneado])
  @@index([pedidoId])
  @@map("gourmet_cargue_escaneos")
}

model GourmetCargueNovedad {
  id              String               @id @default(cuid())
  cargueId        String               @map("cargue_id")
  cargue          GourmetCargue        @relation(fields: [cargueId], references: [id], onDelete: Cascade)
  pedidoId        String               @map("pedido_id")
  pedido          GourmetPedido        @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  tipo            TipoNovedadGourmet
  descripcion     String
  estado          EstadoNovedadGourmet @default(ABIERTA)
  registradaPorId String               @map("registrada_por_id")
  resueltaPorId   String?              @map("resuelta_por_id")
  resueltaAt      DateTime?            @map("resuelta_at")
  createdAt       DateTime             @default(now()) @map("created_at")

  @@index([cargueId])
  @@index([pedidoId])
  @@index([estado])
  @@map("gourmet_cargue_novedades")
}
